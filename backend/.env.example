# Application
APP_NAME=HomeHub NZ
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-secure-random-string
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://homehub:homehub@localhost:5432/homehub

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2
S3_BUCKET_NAME=homehub-nz-uploads

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@homehub.nz

# Redis
REDIS_URL=redis://localhost:6379/0

# Webhooks
WEBHOOK_SECRET=change-me-webhook-secret

# AI (optional)
OPENAI_API_KEY=
AI_PROVIDER=openai

# Push Notifications
EXPO_ACCESS_TOKEN=
FCM_SERVER_KEY=

# CORS
CORS_ORIGINS=["http://localhost:8081","http://localhost:19006","exp://localhost:8081"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
