APP_NAME=HomeHub NZ
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql://homehub:homehub123@localhost:5432/homehub_db

SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Supabase Storage (optional for local dev)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=homehub-uploads

# Local uploads (used when Supabase is not configured)
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://127.0.0.1:8000

# AWS S3 (production — optional)
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2
S3_BUCKET_NAME=

# Expo push notifications (optional)
EXPO_ACCESS_TOKEN=

# Seed demo data on API startup (development)
SEED_DEMO_ON_STARTUP=true
