{
  "expo": {
    "name": "HomeHub NZ",
    "slug": "homehub-nz",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "homehub",
    "userInterfaceStyle": "dark",
    "icon": "./assets/branding/homehub-app-icon.png",
    "backgroundColor": "#4F8CFF",
    "splash": {
      "image": "./assets/branding/homehub-app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F8CFF"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/branding/homehub-app-icon.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "nz.homehub.app"
    },
    "android": {
      "package": "nz.homehub.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/homehub-app-icon.png",
        "backgroundColor": "#FFD84D"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
