# HomeHub NZ frontend environment
# Copy to .env and adjust for your environment.

# FastAPI backend base URL (no trailing slash). Defaults to local dev.
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# WebSocket base URL for realtime chat. Defaults to API host with ws scheme.
EXPO_PUBLIC_WS_URL=ws://127.0.0.1:8000
