# ─── Application ───────────────────────────────────────────
APP_NAME=HomeHub NZ
APP_ENV=development
DEBUG=true

# ─── Security ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-secure-random-string

# ─── Database ──────────────────────────────────────────────
# PostgreSQL runs in Docker; FastAPI runs locally on localhost.
POSTGRES_USER=homehub
POSTGRES_PASSWORD=homehub123
POSTGRES_DB=homehub_db
DATABASE_URL=postgresql://homehub:homehub123@localhost:5432/homehub_db
