# ─── Application ───────────────────────────────────────────
APP_NAME=HomeHub NZ
APP_ENV=development
DEBUG=true

# ─── Security ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-secure-random-string

# ─── Database ──────────────────────────────────────────────
# Use host "db" inside Docker Compose; use "localhost" for local dev.
POSTGRES_USER=homehub
POSTGRES_PASSWORD=homehub123
POSTGRES_DB=homehub_db
DATABASE_URL=postgresql://homehub:homehub123@db:5432/homehub_db
